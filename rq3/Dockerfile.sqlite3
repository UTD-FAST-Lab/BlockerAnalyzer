# rq3/Dockerfile.sqlite3 — sqlite3 (FuzzBench sqlite3_ossfuzz, fuzz_target ossfuzz) built
# with a FuzzBench fuzzer toolchain. Source = sqlite3 amalgamation at the SAME pinned
# tarball revision (r=c78cbf2e86850cc6, == LibAFL_Experiments == FuzzBench benchmark)
# and the SAME single seed ('SELECT 1;') as the prior campaign.
# Build context = /home/miao/work/fuzzbench.
#   docker build --build-arg FUZZER=aflplusplus -f rq3/Dockerfile.sqlite3 \
#       -t rq3-sqlite3-aflplusplus /home/miao/work/fuzzbench
ARG FUZZER=aflplusplus
FROM rq3-toolchain-${FUZZER} AS build
ARG FUZZER
ENV FUZZER=${FUZZER}

RUN apt-get update && apt-get install -y make autoconf automake libtool curl tcl zlib1g-dev zip

# Fetch sqlite3 source at the FuzzBench-pinned tarball revision (mirror benchmarks/
# sqlite3_ossfuzz/Dockerfile: download the amalgamation tarball, strip-components 1
# into $SRC/sqlite3). No git commit — sqlite3 downloads.
RUN mkdir -p $SRC/sqlite3 && \
    cd $SRC/sqlite3 && \
    curl -L 'https://sqlite.org/src/tarball/sqlite.tar.gz?r=c78cbf2e86850cc6' -o sqlite3.tar.gz && \
    tar xzf sqlite3.tar.gz --strip-components 1
WORKDIR $SRC/sqlite3

# FuzzBench's benchmark build.sh (compiles the amalgamation + links $LIB_FUZZING_ENGINE).
# Mirror the FuzzBench Dockerfile's seed-corpus zip + dict so build.sh's trailing
# `cp $SRC/*.dict $SRC/*.zip $OUT/` succeeds.
RUN find $SRC/sqlite3 -name "*.test" | xargs zip $SRC/ossfuzz_seed_corpus.zip
COPY benchmarks/sqlite3_ossfuzz/build.sh $SRC/build.sh
COPY benchmarks/sqlite3_ossfuzz/ossfuzz.dict $SRC/ossfuzz.dict
COPY fuzzers /fuzzbench/fuzzers
RUN python3 -m pip install --upgrade pip >/dev/null 2>&1; python3 -m pip install pyyaml
ENV PYTHONPATH=/fuzzbench FUZZER_LIB=/libAFLDriver.a FUZZ_TARGET=/out/ossfuzz
# Run build() from the SOURCE dir (WORKDIR $SRC/sqlite3) — FuzzBench build.sh does
# `mkdir bld; cd bld; ../configure` and expects cwd == source. PYTHONPATH makes the import work.
RUN mkdir -p /out && python3 -c "from fuzzers.${FUZZER} import fuzzer; fuzzer.build()"

# Same single seed as the prior campaign.
RUN mkdir -p /seeds && printf 'SELECT 1;' > /seeds/seed.sql

# ── runtime ──────────────────────────────────────────────────────────────────
FROM gcr.io/fuzzbench/base-image AS run
ARG FUZZER
ENV FUZZER=${FUZZER}
ENV PATH="$PATH:/out" LD_LIBRARY_PATH="$LD_LIBRARY_PATH:/out"
ENV AFL_SKIP_CPUFREQ=1 AFL_I_DONT_CARE_ABOUT_MISSING_CRASHES=1 AFL_TESTCACHE_SIZE=2
RUN apt-get update && apt-get install -y libbfd-dev libunwind-dev libjemalloc2 2>/dev/null || true
COPY --from=build /out /out
COPY --from=build /seeds /seeds
COPY fuzzers /fuzzbench/fuzzers
RUN python3 -m pip install --upgrade pip >/dev/null 2>&1; python3 -m pip install pyyaml
ENV PYTHONPATH=/fuzzbench OUT=/out FUZZ_TARGET=/out/ossfuzz DURATION=86400
WORKDIR /out
CMD timeout --kill-after=10 --signal=INT ${DURATION} \
      python3 -c "from fuzzers.${FUZZER} import fuzzer; fuzzer.fuzz('/seeds','/corpus','/out/ossfuzz')"; exit 0
